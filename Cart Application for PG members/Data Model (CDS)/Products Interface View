@AccessControl.authorizationCheck: #NOT_REQUIRED
@EndUserText.label: 'Products'
@Metadata.ignorePropagatedAnnotations: false
define root view entity ZI_RJ_PRODUCTS
  as select from I_Product
  association [1..1] to I_ProductValuationBasic as _Valuation on  $projection.Product      = _Valuation.Product
                                                              and _Valuation.ValuationArea = '1710'
                                                              and _Valuation.ValuationType = ''
{
  key Product,
      BaseUnit,
      @Semantics.amount.currencyCode: 'Currency'
      _Valuation.StandardPrice as Price,
      _Valuation.Currency      as Currency,
      
      /*Associations*/
      _Valuation
}
