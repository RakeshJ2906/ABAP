projection;
strict ( 2 );
use draft;
use recommendations;
use side effects;

define behavior for ZRJ_C_TKT_INFO alias TicketInfo
{
  use create;
  use update;
  use delete;

  use association _TktActivity { create; with draft; }

  use action ai_analysis;
  use action add_comments;

  use action Activate;
  use action Edit;
  use action Resume;
  use action Discard;
  use action Prepare;
}

define behavior for ZRJ_C_ACTIVITY alias TicketActivity
{
  use update;
  use delete;

  use association _TktInfo { with draft; }
}
